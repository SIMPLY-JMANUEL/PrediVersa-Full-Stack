# ========================================
# PrediVersa - Variables de Entorno (EJEMPLO)
# ========================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo como .env
# 2. Completa los valores reales
# 3. NUNCA subas el archivo .env real a GitHub
#
# ========================================

# Puerto del servidor
PORT=5003

# Base de datos AWS RDS MySQL (PRODUCCI?N)
DB_HOST=tu-base-de-datos.us-east-1.rds.amazonaws.com
DB_DATABASE=PrediVersa
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=CAMBIAR_ESTA_CONTRASE?A

# ========== AWS BEDROCK - LLAMA 3 CHATBOT ==========
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
CHATBOT_ENABLED=true
CHATBOT_MODEL=llama3_70b

# JWT Token Secret (CAMBIAR POR UNA CLAVE SEGURA)
JWT_SECRET=clave-jwt-muy-segura-cambiar-en-produccion
JWT_EXPIRES_IN=24h

# CORS Origins (separados por coma)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Configuraci�n de Email (para notificaciones)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=tu-app-password

# Configuraci�n de la aplicaci�n
NODE_ENV=production
APP_NAME=PrediVersa
APP_VERSION=1.0.0

# Configuraci�n de seguridad
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOGIN_TIMEOUT_MINUTES=15

# Logging
LOG_LEVEL=info
